# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here-change-me
JWT_EXPIRATION=7d
MAGIC_LINK_EXPIRATION=15m

# Email (Resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=DEV Cfab Pano <noreply@yourdomain.com>
EMAIL_FROM_USE_RESEND_TEST=false

# Database (Neon Postgres – provisioned by Vercel Marketplace integration)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# File storage (Vercel Blob – provisioned by Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
# Opcjonalnie: bazowy URL publicznego store'a (omija pierwsze zapytanie head)
# BLOB_BASE_URL=https://xxxx.public.blob.vercel-storage.com

# Upload limits
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=webp,jpg,jpeg,png

# Initial Admin (used by scripts/seed.ts)
ADMIN_EMAIL=admin@example.com

# Lokalna migracja danych (scripts/migrate-to-vercel.ts):
# PANO_DATA_DIR wskazuje katalog ze starymi danymi (data/ + uploads/projects/)
# PANO_DATA_DIR=
