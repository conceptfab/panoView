# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here-change-me
JWT_EXPIRATION=7d
MAGIC_LINK_EXPIRATION=15m

# Email (Resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=DEV Cfab Panp<noreply@yourdomain.com>
EMAIL_FROM_USE_RESEND_TEST=false

# Storage (lokalnie: brak = katalog roboczy; Railway: PANO_DATA_DIR = Mount Path Volume)
# Np. Volume zamontowany w /pano-data → PANO_DATA_DIR=/pano-data (wszystkie dane tam)
PANO_DATA_DIR=
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=webp,jpg,jpeg,png

# Initial Admin (used by init-data.js on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately

# Railway specific
# PORT=3000 (set automatically by Railway)
