{
  "name": "panorama-platform",
  "version": "0.1.61-beta",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:migrate-data": "dotenv -e .env.local -- tsx scripts/migrate-to-vercel.ts",
    "check-deploy": "node scripts/check-deploy.js",
    "deploy": "node scripts/deploy-vercel.js",
    "deploy:preview": "node scripts/deploy-vercel.js --preview",
    "deploy:ci": "node scripts/deploy-vercel.js --yes",
    "release": "node scripts/release.js",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.4.0",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "extract-zip": "^2.0.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.11",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "react-doctor": "^0.5.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vercel": "^54.12.2",
    "vitest": "^4.1.7"
  }
}
